# Server
PORT=8080
ENV=development

# Database — local dev default. Prod uses Fly Postgres (argus-db.flycast)
# and is set via `fly secrets set DATABASE_URL=... -a argus-ai`, NOT this file.
DATABASE_URL=postgres://postgres:postgres@localhost:5432/argus?sslmode=disable

# GitHub App
GITHUB_APP_ID=123456
GITHUB_PRIVATE_KEY_PATH=./secrets/github-app.pem
GITHUB_WEBHOOK_SECRET=your-webhook-secret

# Clerk (auth)
CLERK_JWKS_URL=https://your-domain.clerk.accounts.dev/.well-known/jwks.json

# CORS (frontend URL)
CORS_ALLOW_ORIGIN=http://localhost:3000

# LLM (OpenAI-compatible)
LLM_API_KEY=sk-or-xxx
LLM_BASE_URL=https://openrouter.ai/api/v1
DEFAULT_REVIEW_MODEL=anthropic/claude-sonnet-4-20250514
DEFAULT_TRIAGE_MODEL=openai/gpt-4o-mini

# Supermemory (optional)
SUPERMEMORY_API_KEY=sm-xxx

# Worker
MAX_CONCURRENT_REVIEWS=5

# Local dev (smee webhook proxy)
SMEE_URL=https://smee.io/your-channel
