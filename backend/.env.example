# ============================================================================
# REQUIRED — the server refuses to start without these
# ============================================================================

# Postgres connection string. `docker compose up db` provides this locally.
DATABASE_URL=postgres://postgres:postgres@localhost:5432/argus?sslmode=disable

# GitHub App webhook secret — set the same value in your GitHub App settings.
GITHUB_WEBHOOK_SECRET=your-webhook-secret

# GitHub App credentials — see docs/self-hosting.md for creating the app.
# Provide the private key by path OR inline PEM (one of the two is required).
GITHUB_APP_ID=123456
GITHUB_PRIVATE_KEY_PATH=./secrets/github-app.pem
# GITHUB_PRIVATE_KEY=

# ============================================================================
# REQUIRED FOR REVIEWS
# ============================================================================

# Encrypts BYOK LLM provider keys at rest. LLM keys are added via the
# dashboard Providers page (stored in the DB), not via env.
# Generate: openssl rand -hex 32
ENCRYPTION_KEY=

# Clerk JWT verification for dashboard API auth. When unset the backend
# FAILS CLOSED: every authenticated API route returns 503 (webhooks and
# reviews still work). There is no auth bypass mode.
CLERK_JWKS_URL=https://your-domain.clerk.accounts.dev/.well-known/jwks.json

# ============================================================================
# OPTIONAL
# ============================================================================

# Server
PORT=8080
ENV=development
CORS_ALLOW_ORIGIN=http://localhost:3000

# Deployment identity (self-hosting)
# Web dashboard base URL, linked from GitHub review comments.
DASHBOARD_BASE_URL=https://argus.reviews
# Public API base URL, used to build signed export links.
API_BASE_URL=https://api.argus.reviews
# Your GitHub App slug, used to build install URLs.
GITHUB_APP_SLUG=argus-eye
# true disables plan gating (self-hosts have no billing).
SELF_HOSTED=false

# HMAC key for signed export URLs — distinct from GITHUB_WEBHOOK_SECRET.
# Unset = signed export links disabled (fail closed).
# Generate: openssl rand -hex 32
WEBHOOK_SECRET=

# Shared secret gating /debug/pprof/* (X-Admin-Token header).
# Unset = pprof routes return 404.
ADMIN_DEBUG_TOKEN=

# Server-side PostHog analytics. Unset = analytics disabled.
POSTHOG_API_KEY=

# Supermemory RAG memory. Unset = memory features off.
SUPERMEMORY_API_KEY=

# Extra logins classified as agents (comma-separated), on top of built-in
# "[bot]" / "-bot" / "-agent" suffix detection.
ARGUS_AGENT_LOGINS=

# Max linked PRs enriched per review, clamped to (0,20]. Default 5.
ARGUS_MAX_LINKED_PRS=5

# Worker
MAX_CONCURRENT_REVIEWS=5

# Memory profiler (see backend/docs/memprof.md)
MEMPROF_ENABLED=true
MEMPROF_INTERVAL_SEC=30
MEMPROF_RSS_THRESHOLD_MB=400
MEMPROF_COOLDOWN_SEC=300
MEMPROF_DUMP_DIR=/tmp
MEMPROF_LOG_BASE64=false

# Local dev webhook relay — create your own channel at https://smee.io
SMEE_URL=https://smee.io/your-channel
